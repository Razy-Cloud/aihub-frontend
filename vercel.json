{
  "version": 2,
  "public": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ],
  "static": {
    "upload": [
      "index.html",
      "admin.html",
      "css/**/*.css",
      "js/**/*.js"
    ]
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://aihub-backend-app-production.up.railway.app/api/$1"
    },
    {
      "source": "/((?!admin.html$).*)",
      "destination": "/index.html"
    }
  ]
}