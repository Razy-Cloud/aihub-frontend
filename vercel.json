{
  "name": "aihub-frontend",
  "version": 2,
  "public": true,
  "static": {
    "upload": [
      "index.html",
      "admin.html",
      "css/**/*.css",
      "js/**/*.js"
    ]
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://aihub-backend-app-production.up.railway.app/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
